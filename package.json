{
  "name": "sluice",
  "version": "1.0.0",
  "description": "Reserve-aware JIT inbound liquidity primitive for Fiber",
  "type": "module",
  "main": "./dist/package.cjs",
  "module": "./dist/package.js",
  "types": "./dist/package.d.ts",
  "exports": {
    ".": {
      "types": "./dist/package.d.ts",
      "import": "./dist/package.js",
      "require": "./dist/package.cjs"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js",
      "require": "./dist/sdk/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:package": "node scripts/package-smoke.mjs",
    "demo": "tsx scripts/demo.ts",
    "demo:doctor": "tsx scripts/demo-doctor.ts",
    "demo:dry": "tsx scripts/demo-dry.ts",
    "demo:proof": "tsx scripts/demo-proof.ts",
    "dev": "tsx src/index.ts",
    "spike": "tsx scripts/spike-channel-open.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
